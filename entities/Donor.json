{
  "name": "Donor",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "OSC a la que pertenece este donante"
    },
    "donor_type": {
      "type": "string",
      "enum": [
        "fisica",
        "moral"
      ],
      "default": "fisica"
    },
    "full_name": {
      "type": "string",
      "description": "Nombre completo o Raz\u00f3n Social"
    },
    "rfc": {
      "type": "string"
    },
    "curp": {
      "type": "string",
      "description": "Solo persona f\u00edsica"
    },
    "birth_date": {
      "type": "string",
      "format": "date"
    },
    "nationality": {
      "type": "string",
      "default": "Mexicana"
    },
    "country_of_incorporation": {
      "type": "string",
      "description": "Para persona moral"
    },
    "incorporation_date": {
      "type": "string",
      "format": "date"
    },
    "activity": {
      "type": "string",
      "description": "Actividad/Objeto social"
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "zip_code": {
      "type": "string"
    },
    "country": {
      "type": "string",
      "default": "M\u00e9xico"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "legal_rep_name": {
      "type": "string"
    },
    "legal_rep_rfc": {
      "type": "string"
    },
    "legal_rep_curp": {
      "type": "string"
    },
    "legal_rep_birth_date": {
      "type": "string",
      "format": "date"
    },
    "legal_rep_id_authority": {
      "type": "string"
    },
    "legal_rep_id_number": {
      "type": "string"
    },
    "beneficial_owner_exists": {
      "type": "boolean",
      "default": false
    },
    "beneficial_owner_name": {
      "type": "string"
    },
    "beneficial_owner_rfc": {
      "type": "string"
    },
    "pep_flag": {
      "type": "boolean",
      "default": false,
      "description": "Persona Pol\u00edticamente Expuesta"
    },
    "reputation_flag": {
      "type": "boolean",
      "default": false
    },
    "reputation_notes": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "low"
    },
    "compliance_status": {
      "type": "string",
      "enum": [
        "ok",
        "identification_required",
        "notice_required",
        "blocked",
        "incomplete"
      ],
      "default": "incomplete"
    },
    "kyc_complete": {
      "type": "boolean",
      "default": false
    },
    "portal_user_email": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "blocked",
        "pending"
      ],
      "default": "pending"
    }
  },
  "required": [
    "organization_id",
    "donor_type",
    "full_name"
  ]
}