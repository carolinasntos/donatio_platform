{
  "name": "DonorDocument",
  "type": "object",
  "properties": {
    "donor_id": {
      "type": "string"
    },
    "organization_id": {
      "type": "string"
    },
    "document_type": {
      "type": "string",
      "enum": [
        "acta_constitutiva",
        "comprobante_domicilio",
        "poder_representante",
        "identificacion_representante",
        "cedula_fiscal",
        "constancia_dueno_beneficiario",
        "identificacion_dueno_beneficiario",
        "otro"
      ]
    },
    "document_name": {
      "type": "string"
    },
    "file_url": {
      "type": "string"
    },
    "upload_date": {
      "type": "string",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    },
    "is_verified": {
      "type": "boolean",
      "default": false
    },
    "verified_by": {
      "type": "string"
    },
    "verified_date": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    },
    "version": {
      "type": "number",
      "default": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "valid",
        "expired",
        "rejected"
      ],
      "default": "pending"
    }
  },
  "required": [
    "donor_id",
    "organization_id",
    "document_type"
  ]
}